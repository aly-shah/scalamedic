  doctorId    String?         @db.Uuid
  doctor      User?           @relation("BlockedSlots", fields: [doctorId], references: [id], onDelete: SetNull)
  roomId      String?         @db.Uuid
  room        Room?           @relation("BlockedSlotRoom", fields: [roomId], references: [id], onDelete: SetNull)
  branchId    String?         @db.Uuid
  branch      Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
