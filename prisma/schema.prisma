// ---- Calendar Blocked Slots ----

enum BlockedSlotType {
  BREAK
  LUNCH
  PRAYER
  MEETING
  MAINTENANCE
  LEAVE
  EMERGENCY_HOLD
  MANUAL
}

model BlockedSlot {
