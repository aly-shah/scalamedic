# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Release artifacts — built locally, rsync'd to the VPS via deploy. The
# APK lives here because Next.js static-serves /public, but it shouldn't
# bloat the git repo (5 MB per release).
/public/medicore-cc.apk

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# android (capacitor) build artifacts
/android/.gradle
/android/app/build
/android/build
/android/captures
/android/local.properties
/android/*.iml
