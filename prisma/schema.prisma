// ---- Refunds ----

model Refund {
  id            String             @id @default(uuid()) @db.Uuid
  invoiceId     String             @db.Uuid
  invoice       Invoice            @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  amount        Decimal            @db.Decimal(10, 2)
  reason        String             @db.Text
  status        RefundStatus       @default(REQUESTED)
  method        PaymentMethodType?
  reference     String?            @db.VarChar(100)
  approvedById  String?            @db.Uuid
  approvedBy    User?              @relation("RefundsApproved", fields: [approvedById], references: [id], onDelete: SetNull)
  // SetNull mirrors v11's AuditLog change — a hard-deleted processor user
  // shouldn't block a historical refund record.
  processedById String?            @db.Uuid
  processedBy   User?              @relation("RefundsProcessed", fields: [processedById], references: [id], onDelete: SetNull)
  processedAt   DateTime?
  notes         String?            @db.Text
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([invoiceId])
  @@index([status])
  @@index([approvedById])
  @@index([processedById])
  @@map("refunds")
}

// v58 — Insurance claim. One claim per submission to an insurer; an
// invoice can have multiple claims over time (initial DRAFT plus an
// APPEAL after a DENIED). Numbers are per-tenant unique using the
// CLM-YYYY-NNNN scheme (mirrors invoiceNumber from v53).
//
// Diagnosis codes are *snapshot* on the claim row at submit time —
// editing the consultation note later does not change what the
// insurer was told. This matches how real-world clinics handle
// claim audits.
model InsuranceClaim {
  id              String   @id @default(uuid()) @db.Uuid
  claimNumber     String   @db.VarChar(30) // CLM-2026-0001

  // Source invoice + denormalized scope. Restrict-on-delete preserves
  // the audit trail; a settled claim shouldn't disappear because the
  // invoice was archived.
  invoiceId       String   @db.Uuid
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  patientId       String   @db.Uuid
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Restrict)
  insuranceId     String   @db.Uuid
  insurance       Insurance @relation(fields: [insuranceId], references: [id], onDelete: Restrict)
  branchId        String   @db.Uuid
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  // tenantId denormalized; trigger keeps it == branch.tenantId (v53 pattern).
  tenantId        String   @db.Uuid
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  /// Snapshot of ICD-10 diagnosis codes at submit time. Independent
  /// of consultation_notes.icd10Codes — the note can be amended later
  /// without rewriting submitted claims.
  diagnosisCodes  String[] @default([])

  // Amounts (Decimal(14,2), PKR). claimedAmount is what we asked for,
  // approvedAmount is what the insurer agreed to (set on decision),
  // paidAmount is what they actually wired. copayCollected tracks
  // the patient's share already taken at the desk.
  claimedAmount   Decimal  @db.Decimal(14, 2)
  approvedAmount  Decimal? @db.Decimal(14, 2)
  paidAmount      Decimal  @default(0) @db.Decimal(14, 2)
  copayCollected  Decimal  @default(0) @db.Decimal(14, 2)

  status          InsuranceClaimStatus @default(DRAFT)

  // Lifecycle timestamps. Populated as the claim moves through the
  // status enum; CHECKs in the v58 migration enforce ordering.
  submittedAt     DateTime? @db.Timestamptz(6)
  decidedAt       DateTime? @db.Timestamptz(6)
  paidAt          DateTime? @db.Timestamptz(6)

  /// Insurer's tracking reference (their internal claim id).
  insurerReference String? @db.VarChar(80)
  /// Required when status=DENIED to keep the audit trail useful.
  denialReason     String? @db.Text
  /// v60 — Optional FK into the per-tenant DenialReason taxonomy.
  /// Coexists with the free-text `denialReason` field; pickers fill
  /// both. SetNull on payer-side delete keeps historical claims
  /// readable if an admin retires a code.
  denialReasonCodeId String? @db.Uuid
  denialReasonCode DenialReason? @relation("InsuranceClaimDenialReason", fields: [denialReasonCodeId], references: [id], onDelete: SetNull)
  notes            String? @db.Text

  createdById     String   @db.Uuid
  createdBy       User     @relation("InsuranceClaimCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, claimNumber])
  @@index([tenantId])
  @@index([patientId])
  @@index([invoiceId])
  @@index([insuranceId])
  @@index([branchId])
  @@index([status])
  @@index([denialReasonCodeId])
  @@index([branchId, createdAt(sort: Desc)])
  @@map("insurance_claims")
}

// ---- Product / Inventory ----

model Product {
  id           String          @id @default(uuid()) @db.Uuid
  name         String          @db.VarChar(150)
  sku          String?         @unique @db.VarChar(30)
  // PostgreSQL treats multiple NULLs as distinct under UNIQUE, so we don't need
  // a partial predicate here — products without a barcode coexist freely.
  barcode      String?         @unique @db.VarChar(30)
  category     ProductCategory
  brand        String?         @db.VarChar(80)
  description  String?         @db.Text
  costPrice    Decimal         @db.Decimal(10, 2)
  sellPrice    Decimal         @db.Decimal(10, 2)
  quantity     Int             @default(0)
  reorderLevel Int             @default(5)
  unit         String?         @db.VarChar(20) // "ml", "tube", "bottle"
  expiryDate   DateTime?       @db.Date
  branchId     String          @db.Uuid
  branch       Branch          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  isActive     Boolean         @default(true)
  imageUrl     String?         @db.Text
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  invoiceItems InvoiceItem[]

  @@index([branchId])
  @@index([category])
  @@index([sku])
  @@index([quantity]) // low stock alerts
  @@index([expiryDate])
  @@index([branchId, isActive]) // "active stock per branch" listings
  @@map("products")
}

