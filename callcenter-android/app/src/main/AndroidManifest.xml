<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Call log + phone state -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_PHONE_NUMBERS" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <!-- Live outbound tracking: ACTION_NEW_OUTGOING_CALL is gated on this
         permission. Deprecated but still the only mechanism to capture the
         dialed number before the call connects. -->
    <uses-permission android:name="android.permission.PROCESS_OUTGOING_CALLS" />

    <!-- Dashboard-driven phone control (CallControlPoller):
         CALL_PHONE         — place outbound calls when the receptionist
                              clicks a patient's number on the dashboard
         ANSWER_PHONE_CALLS — accept ringing inbound calls + endCall() on
                              active calls (TelecomManager) when the
                              dashboard's Answer / Hang up buttons fire -->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.ANSWER_PHONE_CALLS" />

    <!-- Foreground service on Android 14+ requires a type + the matching permission -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Start services on boot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Post notifications (Android 13+) for the foreground-service notification -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Lets us *request* exemption from battery optimisation so the
         OEM doesn't kill the foreground service. Required for the
         app's reliability on Xiaomi/MIUI, Oppo/ColorOS, Vivo,
         Huawei, etc. — the user still has to confirm in the system
         dialog. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:allowBackup="false"
        android:forceDarkAllowed="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.MediCore"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Foreground service that owns the CallLog ContentObserver -->
        <service
            android:name=".CallLogObserverService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- NotificationListenerService for WhatsApp -->
        <service
            android:name=".WhatsAppListener"
            android:exported="true"
            android:label="MediCore WhatsApp Listener"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Restart foreground service on device boot -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
