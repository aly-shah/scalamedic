model Insurance {
  id           String    @id @default(uuid()) @db.Uuid
  patientId    String    @db.Uuid
  patient      Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  /// Free-text payer name. Kept for legacy + free-form entries
  /// (international policies, niche payers not yet in the master).
  /// New entries should also set payerId — the Payer row carries
  /// the standardized code, billing email, etc.
  provider     String    @db.VarChar(120)
  /// v59 — Optional FK to the tenant's payer master (Payer model).
  /// Nullable on rollout so existing free-text rows keep working;
  /// the patient-insurance form upserts both fields going forward.
  payerId      String?   @db.Uuid
  payer        Payer?    @relation(fields: [payerId], references: [id], onDelete: SetNull)
  policyNumber String    @db.VarChar(60)
  coverageType String?   @db.VarChar(40)
  copayAmount  Decimal?  @db.Decimal(10, 2)
  expiryDate   DateTime? @db.Date
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  claims       InsuranceClaim[]

