generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================
// ENUMS
// =============================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  RECEPTIONIST
  BILLING
  CALL_CENTER
  ASSISTANT
  /// Performs aesthetic treatments (laser, peels, facials, injectables
  /// supervised by a doctor). Sits between ASSISTANT and DOCTOR — has
  /// hands-on procedure access, no prescribing.
  AESTHETICIAN
  /// Equipment operator (laser machine, IV chairs, etc). View-mostly
  /// — sees the schedule + assigned patients but doesn't edit clinical
  /// records.
  OPERATOR
  /// Self-service patient account. Pinned to the lowest tier of the
  /// role hierarchy; explicitly excluded from any staff-only API
  /// path. Read access scoped to their own Patient record (linked
  /// via Patient.userId) plus the Phase-3 companion-app surfaces.
  PATIENT
}

/// Status of a patient invite. PENDING is freshly issued; ACCEPTED
/// has been redeemed (the User row exists and Patient.userId is set);
/// EXPIRED / REVOKED are terminal states that can't be redeemed.
enum PatientInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

