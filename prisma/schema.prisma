// v60 — Per-tenant master of common denial reasons. Free-text
// `denialReason` on InsuranceClaim still works for one-off cases;
// `denialReasonCode` (FK below) snaps to a curated taxonomy so
// reports can group "all claims denied for missing pre-auth" without
// fuzzy text matching.
model DenialReason {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Per-tenant unique short code (e.g. "AUTH-MISSING").
  code      String   @db.VarChar(40)
  description String @db.VarChar(200)
  /// Surface high-frequency reasons at the top of the picker without
  /// requiring a search query — same convention as ICD10Code.
  isCommon  Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  claims    InsuranceClaim[] @relation("InsuranceClaimDenialReason")

  @@unique([tenantId, code])
  @@index([tenantId, isCommon, isActive])
  @@map("denial_reasons")
}

// v59 — Per-tenant payer (insurance company) master list. Replaces
// the free-text Insurance.provider field for new entries; legacy
// rows keep their string until edited. Standardized codes (the
// payer's own filing identifier, e.g. "EFU-LIFE-HC") drive payer
// reports and per-payer claim analytics.
model Payer {
  id                    String   @id @default(uuid()) @db.Uuid
  tenantId              String   @db.Uuid
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                  String   @db.VarChar(120)
  /// Short stable identifier for filings. Per-tenant unique. Caps,
  /// alphanumerics, hyphens, max 40 chars.
  code                  String   @db.VarChar(40)
  /// Optional contact email for general queries.
  contactEmail          String?  @db.VarChar(180)
  /// Where claims should be submitted (often a different mailbox
  /// than general contact).
  claimSubmissionEmail  String?  @db.VarChar(180)
  contactPhone          String?  @db.VarChar(32)
  notes                 String?  @db.Text
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  insurances            Insurance[]

  @@unique([tenantId, code])
  @@unique([tenantId, name])
  @@index([tenantId, isActive])
  @@map("payers")
}

// ---- Scheduling ----

model Appointment {
  id               String            @id @default(uuid()) @db.Uuid
  // v53: appointmentCode is per-tenant unique (composite below).
  appointmentCode  String            @db.VarChar(20) // APT-0001
  patientId        String            @db.Uuid
  patient          Patient           @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctorId         String            @db.Uuid
  doctor           User              @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Restrict)
  branchId         String            @db.Uuid
  branch           Branch            @relation(fields: [branchId], references: [id], onDelete: Restrict)
  // v53: denormalized tenant FK; trigger keeps it == branch.tenantId.
  tenantId         String            @db.Uuid
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  roomId           String?           @db.Uuid
  room             Room?             @relation(fields: [roomId], references: [id], onDelete: Restrict)
  date             DateTime          @db.Date
  startTime        String            @db.VarChar(5) // "09:00"
  endTime          String            @db.VarChar(5) // "09:30"
  durationMinutes  Int               @default(30)
  type             AppointmentType
  // Optional treatment selected at booking. Carries forward to the
  // check-in invoice as a line item (basePrice from the treatment).
  treatmentId      String?           @db.Uuid
  treatment        Treatment?        @relation("AppointmentTreatment", fields: [treatmentId], references: [id], onDelete: SetNull)
  status           AppointmentStatus @default(SCHEDULED)
  notes            String?           @db.Text
  priority         Priority          @default(NORMAL)
  waitlistPosition Int?
  checkinTime      DateTime?         @db.Timestamptz(6)
  checkoutTime     DateTime?         @db.Timestamptz(6)
  workflowStage    WorkflowStage     @default(BOOKED)
  // v63: where this booking came from. STAFF for receptionist-
  // created rows (the default), WEBSITE for public /book wizard,
  // API for service-account integrations, PATIENT_PORTAL for self-
  // service rebooks from /portal.
  source           AppointmentSource @default(STAFF)
  cancellationNote String?           @db.Text
  // v64: who/when of the cancellation. Both nullable for historical
  // rows whose status pre-dated these columns. CHECK constraint in
  // the v64 migration enforces cancelledAt → status='CANCELLED'.
  cancelledAt      DateTime?         @db.Timestamptz(6)
  cancelledById    String?           @db.Uuid
  cancelledBy      User?             @relation("AppointmentCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  createdById      String            @db.Uuid
  createdBy        User              @relation("CreatedAppointments", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  consultationNotes ConsultationNote[]
  procedures        Procedure[]
  prescriptions     Prescription[]
  labTests          LabTest[]
  invoices          Invoice[]
  followUps         FollowUp[]
  transcriptions    AITranscription[]
  aiSuggestions     AISuggestion[]      @relation("AISuggestionAppointment")
  vitals            Vitals[]
  consentForms      ConsentForm[]
  waitlistBookings  Waitlist[]
  qrTokens          QrToken[]

  // [patientId], [doctorId], [branchId] dropped — each is a redundant prefix
  // of a larger composite below.
  @@unique([tenantId, appointmentCode])
  @@index([tenantId])
  @@index([date])
  @@index([status])
  @@index([doctorId, date]) // doctor daily schedule
  @@index([branchId, date]) // branch daily schedule
  @@index([patientId, date]) // patient history lookup
  @@index([patientId, status]) // dashboard "active appointments per patient"
  @@index([workflowStage]) // workflow queue queries
  @@index([roomId])
  @@index([createdById])
  @@index([treatmentId])
  @@index([checkinTime]) // "checked in today" reception filter
  @@index([date, status]) // daily status breakdown reports
  @@map("appointments")
}

model Room {
