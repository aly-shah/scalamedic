// =============================================
// MODELS
// =============================================

// ---- Multi-Branch ----

model Branch {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(120)
  // v53: branch code uniqueness is now per-tenant (was global). Two
  // tenants can both have a "MAIN" branch. The composite index lives
  // in @@unique below.
  code      String   @db.VarChar(10) // e.g. "MAIN", "DT", "WS"
  address   String   @db.Text
  phone     String   @db.VarChar(32)
  email     String   @db.VarChar(120)
  timezone  String   @default("Asia/Karachi") @db.VarChar(40)
  isActive  Boolean  @default(true)
  // Tenant scoping. Single-tenant deployments backfill to one
  // Tenant row; multi-tenant deployments (Phase 3 expansion) use
  // this to isolate clinic chains. Nullable on the schema because
  // Prisma doesn't yet support set-NOT-NULL-after-backfill in a
  // single migration; the v36 migration backfills + enforces NOT
  // NULL via raw SQL.
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  patients     Patient[]
  appointments Appointment[]
  rooms        Room[]
  invoices     Invoice[]
  insuranceClaims InsuranceClaim[]
  leads        Lead[]
  products     Product[]
  blockedSlots BlockedSlot[]
  // Many-to-many catalog availability — one row per (treatment|package, branch)
  // pair. Backfilled to "every treatment available at every branch" by v24,
  // admins can narrow per-item via the catalog UI.
  treatments   TreatmentBranch[]
  packages     PackageBranch[]

  pettyCashExpenses PettyCashExpense[]
  dailyClosings     DailyClosing[]
  procedureProtocols ProcedureProtocol[]

  @@unique([tenantId, code])
  @@index([isActive])
  @@index([tenantId])
  @@map("branches")
}

// Multi-tenant root. Today the platform deploys with exactly one
// row (Nakhoda Skin Institute); the model exists so future clinic-
// chain or SaaS deployments can isolate per tenant without a
// painful retrofit. Tenant-scoping is enforced via Branch.tenantId
// (every branch belongs to one tenant) — clinical data inherits
// scope through the branch.
enum TenantPlan {
  FREE
  PRO
  ENTERPRISE
}

model Tenant {
  id              String   @id @default(uuid()) @db.Uuid
  // URL-safe slug used to resolve a tenant by hostname/path in
  // multi-tenant deployments. Globally unique.
  slug            String   @unique @db.VarChar(60)
  // Display names. `name` is the marketing name (used in UI
  // headers, browser tabs); `legalName` is the registered entity
  // name (used on invoices); `shortName` is the compact sidebar
  // label.
  name            String   @db.VarChar(150)
  legalName       String?  @db.VarChar(200)
  shortName       String?  @db.VarChar(60)
  // SaaS plan tier. Drives feature gates: requireFeature() and the
  // client-side useFeature() hook both look up FEATURES_BY_PLAN
  // (lib/feature-gate.ts) keyed by this. ENTERPRISE is the default
  // for the existing single-tenant deployment so nothing breaks on
  // rollout — new tenants would default to FREE.
  plan            TenantPlan @default(ENTERPRISE)
  // Optional plan expiry. Null = active indefinitely (useful for
  // paid customers before a billing system is wired up). When set
  // and in the past, the feature gate degrades the tenant to FREE.
  planValidUntil  DateTime? @db.Timestamptz(6)
  // Brand assets. Stored as paths/URLs; logoUrl is the canonical
  // wordmark used across surfaces, faviconUrl is the browser-tab
  // icon. Null means "use the platform default".
  logoUrl         String?  @db.Text
  // v62 — horizontal wordmark for wide surfaces (printed receipt).
  // The receipt prefers this when set; falls back to logoUrl and
  // then to a text masthead. Nullable so existing tenants keep
  // their current behavior.
  wordmarkUrl     String?  @db.Text
  faviconUrl      String?  @db.Text
  // OTPAuth issuer name shown in authenticator apps. Defaults to
  // the platform name when null.
  mfaIssuer       String?  @db.VarChar(60)
  // Footer credit on patient-facing artifacts (receipts, etc.).
  // Defaults to "Powered by ScalaMedic" platform-wide.
  poweredByLine   String?  @db.VarChar(80)
  // Brand color hint (Tailwind palette name or hex). Future-use
  // for theme overrides; today the UI ignores it.
  primaryColor    String?  @db.VarChar(20)
  isActive        Boolean  @default(true)
  // Demo tenant flag (v52). When true, the workspace is treated as a
  // disposable sandbox: a top-banner warns "Demo workspace", the
  // /api/admin/demo/reset endpoint is allowed to wipe + regenerate
  // its data, and the login page can offer a one-click "Try demo"
  // sign-in. Real tenants must keep this false.
  isDemo          Boolean  @default(false)
  // v61 — locale / currency / tax-scheme. Together they let a single
  // platform serve PK and US tenants concurrently. Defaults preserve
  // pre-v61 behavior. CHECK constraints (in the v61 migration) enforce
  // ISO 4217, BCP 47 country sub-tag, and two-letter scheme codes.
  currency        String   @default("PKR") @db.VarChar(3)   // ISO 4217 (PKR, USD, ...)
  locale          String   @default("en-PK") @db.VarChar(10) // BCP 47 (en-PK, en-US, ...)
  taxScheme       String   @default("PK") @db.VarChar(2)    // "PK" | "US"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branches        Branch[]
  users           User[]
  patients        Patient[]
  appointments    Appointment[]
  invoices        Invoice[]
  codeCounters    TenantCodeCounter[]
  insuranceClaims InsuranceClaim[]
  payers          Payer[]
  denialReasons   DenialReason[]
  procedureProtocols ProcedureProtocol[]
  collaborationThreads CollaborationThread[] @relation("CollaborationThreadTenant")
  hostnames       TenantHostname[]

  @@index([isActive])
  @@map("tenants")
}

// Hostnames that route to this tenant. The Next.js middleware
// resolves the incoming request's `Host` header against this
// table; matched requests get a `X-Resolved-Tenant-Id` header
// threaded into downstream routes (lib/tenant.ts reads it).
//
// Single-tenant deployments need at least one row per active
// tenant; the migration seeds the existing nakhoda tenant with
// its production + dev hostnames. Multi-tenant SaaS expansion
// adds more rows without code changes.
model TenantHostname {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Lower-cased FQDN. Globally unique — two tenants can never
  // claim the same hostname. Length capped at 120; longer FQDNs
  // are rare and can be aliased.
  hostname  String   @unique @db.VarChar(120)
  // Exactly one primary hostname per tenant, enforced via the
  // partial unique index in v51's migration. The primary is the
  // one referenced in invitation links and patient-facing emails.
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@map("tenant_hostnames")
}

// v65: per-tenant code counters for race-safe sequence generation
// (PT-NNNN, APT-NNNN, INV-YYYY-NNNN, CLM-YYYY-NNNN, …). The
// MAX(code)+1 pattern across the codebase is correct under single-
// writer load but collides under concurrent inserts. The helper at
// src/lib/tenant-codes.ts:nextCode() uses an INSERT … ON CONFLICT
// DO UPDATE … RETURNING against this table, which is atomic at the
// row level. codePrefix carries the year for date-rolled series
// (e.g. "INV-2026") so the rollover on 1 Jan is automatic — a fresh
// row gets created for the new year and starts at 1.
model TenantCodeCounter {
  tenantId   String   @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  codePrefix String   @db.VarChar(8)
  nextNumber Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@id([tenantId, codePrefix])
  @@map("tenant_code_counters")
}

// ---- Auth & Access ----

model User {
  id              String    @id @default(uuid()) @db.Uuid
  // No longer globally unique — multi-tenant SaaS allows the same
  // email to exist as different users in different tenants.
  // Composite uniqueness on (tenantId, email) enforced via
  // @@unique below.
  email           String    @db.VarChar(180)
  passwordHash    String    @db.VarChar(255)
  name            String    @db.VarChar(120)
  phone           String?   @db.VarChar(32)
  avatar          String?   @db.Text
  role            UserRole
  branchId        String    @db.Uuid
  branch          Branch    @relation(fields: [branchId], references: [id], onDelete: Restrict)
  // Tenant convenience FK — duplicates branch.tenantId for fast
  // queries. Kept consistent by application code (set on create
  // from branch.tenantId; cannot drift since v36 enforces a
  // CHECK that user.tenantId = branch.tenantId).
  tenantId        String    @db.Uuid
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  speciality      String?   @db.VarChar(100) // for doctors
  licenseNumber   String?   @unique @db.VarChar(60) // for doctors — PMC license #
  // Default consultation fee in PKR. Used by the check-in pay-then-proceed
  // flow as the first invoice line item; receptionist can override at
  // collection time. Null = no default set yet.
  consultationFee Decimal?  @db.Decimal(10, 2)
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  // When this admin last opened /admin/updates. Drives the "unread"
  // badge: anything (review, booking, message) created strictly after
  // this timestamp is counted as unread for the sidebar pip. NULL =
  // never opened, treat everything as unread.
  lastUpdatesSeenAt DateTime?
  // MFA (TOTP). The secret is stored encrypted-at-rest using
  // MFA_SECRET_KEY (AES-256-GCM, see lib/mfa-crypto.ts) so a DB
  // dump alone doesn't yield code-generation capability. Both
  // ciphertext and iv are base64 strings.
  mfaEnabled              Boolean @default(false)
  mfaSecretCiphertext     String? @db.Text
  mfaSecretIv             String? @db.VarChar(32)
  mfaSecretAuthTag        String? @db.VarChar(32)
  mfaEnrolledAt           DateTime? @db.Timestamptz(6)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  permissions         Permission[]
  auditLogs           AuditLog[]
  assignedPatients    Patient[]          @relation("AssignedDoctor")
  doctorAppointments  Appointment[]      @relation("DoctorAppointments")
  createdAppointments Appointment[]      @relation("CreatedAppointments")
  cancelledAppointments Appointment[]    @relation("AppointmentCancelledBy")
  consultationNotes   ConsultationNote[]
  procedures          Procedure[]
  prescriptions       Prescription[]
  labTestsOrdered     LabTest[]          @relation("DoctorLabTests")
  documents           PatientDocument[]
  photoScoresCreated  PhotoScore[]
  invoicesCreated     Invoice[]
  insuranceClaimsCreated InsuranceClaim[] @relation("InsuranceClaimCreator")
  paymentsProcessed   Payment[]
  assignedLeads       Lead[]
  callLogs            CallLog[]
  communications      CommunicationLog[]
  followUps           FollowUp[]         @relation("DoctorFollowUps")
  transcriptions      AITranscription[]
  notifications       Notification[]
  vitalsRecorded      Vitals[]
  schedules           DoctorSchedule[]
  refundsApproved     Refund[]           @relation("RefundsApproved")
  refundsProcessed    Refund[]           @relation("RefundsProcessed")
  leaves              DoctorLeave[]      @relation("DoctorLeaves")
  leavesApproved      DoctorLeave[]      @relation("DoctorLeaveApprover")
  roomAllocations     RoomAllocation[]   @relation("RoomAllocations")
  waitlistAssigned    Waitlist[]         @relation("WaitlistDoctor")
  blockedSlots        BlockedSlot[]      @relation("BlockedSlots")
  blockedSlotsCreated BlockedSlot[]      @relation("BlockedSlotCreator")
  pettyCashRecorded   PettyCashExpense[] @relation("PettyCashRecorded")
  dailyClosingsClosed DailyClosing[]     @relation("DailyClosingClosedBy")
  permissionOverridesCreated RolePermissionOverride[] @relation("RolePermissionOverrideCreator")
  qrTokensCreated     QrToken[]
  qrScans             QrScanLog[]
  websiteBookingOverridesUpdated WebsiteBookingOverride[] @relation("WebsiteBookingOverrideUpdater")
  websiteMessageOverridesUpdated WebsiteMessageOverride[] @relation("WebsiteMessageOverrideUpdater")
  consultationNotesSigned       ConsultationNote[]            @relation("ConsultationNoteSigner")
  consultationNoteRevisions     ConsultationNoteRevision[]    @relation("ConsultationNoteRevisionAuthor")
  aiSuggestionsForMe            AISuggestion[]                @relation("AISuggestionDoctor")
  aiSuggestionsDecided          AISuggestion[]                @relation("AISuggestionDecider")
  // Self-service patient account: at most one Patient row points at
  // this user (via Patient.userId). Optional inverse for queries.
  patient                       Patient?                      @relation("PatientUser")
  invitesSent                   PatientInvite[]               @relation("PatientInviteCreator")
  procedureConsentsWitnessed    Procedure[]                   @relation("ProcedureConsentWitness")
  procedureProtocolsCreated     ProcedureProtocol[]           @relation("ProcedureProtocolCreator")
  collaborationThreadsCreated   CollaborationThread[]         @relation("CollaborationThreadCreator")
  collaborationCommentsAuthored CollaborationComment[]        @relation("CollaborationCommentAuthor")
  collaborationMentions         CollaborationMention[]        @relation("CollaborationMentionTarget")
  revokedSessions               RevokedSession[]
  labTestResultsEntered         LabTestResult[]               @relation("LabTestResultEnterer")

  @@unique([tenantId, email])
  @@index([role])
  @@index([branchId])
  @@index([tenantId])
  @@index([lastLoginAt]) // "active staff this week" dashboard
  @@index([role, branchId]) // staff filter by role within a branch
  @@map("users")
}

model Permission {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module    String   @db.VarChar(60) // e.g. "PATIENT", "APPOINTMENT"
  action    String   @db.VarChar(20) // VIEW, CREATE, EDIT, DELETE, EXPORT
  granted   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, module, action])
  @@index([userId])
  @@index([module]) // admin "all permissions for module X" lookups
  @@map("permissions")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  // Nullable: system jobs / webhook events have no real user, and a deleted
  // user shouldn't blow up audit history (FK becomes SetNull instead of Restrict).
  userId     String?  @db.Uuid
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String   @db.VarChar(30)
  module     String   @db.VarChar(60)
  entityType String   @db.VarChar(60)
  entityId   String   @db.VarChar(60)
  details    Json?
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.VarChar(300)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([module])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([action]) // filter all events of one action type (e.g. DEACTIVATED)
  @@map("audit_logs")
}

// ---- Patient Core ----

model Patient {
  id               String          @id @default(uuid()) @db.Uuid
  // v53: patientCode is now per-tenant unique (was globally unique).
  // Composite index lives in @@unique below.
  patientCode      String          @db.VarChar(20) // PT-0001
  firstName        String          @db.VarChar(60)
  middleName       String?         @db.VarChar(60)
  lastName         String          @db.VarChar(60)
  // email uniqueness is enforced via a partial unique index defined in the v11
  // migration: UNIQUE (email) WHERE email IS NOT NULL AND deletedAt IS NULL.
  // Prisma can't model partial uniques, so we keep the column non-unique here
  // and rely on the raw index. phone is intentionally not unique — family
  // members commonly share numbers in PK clinics.
  email            String?         @db.VarChar(180)
  phone            String?         @db.VarChar(32)
  // Optional — receptionists frequently register a walk-in / urgent patient
  // without confirmed DOB and fill it in later. The two existing CHECKs
  // (not-future from v14, >= 1900-01-01 from v19) are NULL-safe.
  dateOfBirth      DateTime?       @db.Date
  gender           Gender
  nationality      String?         @db.VarChar(60)
  address          String?         @db.Text
  city             String?         @db.VarChar(80)
  emergencyContact String?         @db.VarChar(120)
  emergencyPhone   String?         @db.VarChar(32)
  bloodType        String?         @db.VarChar(5)
  skinType         SkinTypeScale?
  branchId         String          @db.Uuid
  branch           Branch          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  // v53: denormalized tenant FK (mirrors users.tenantId). Trigger
  // patients_enforce_branch_tenant_trg keeps this == branch.tenantId.
  tenantId         String          @db.Uuid
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  assignedDoctorId String?         @db.Uuid
  assignedDoctor   User?           @relation("AssignedDoctor", fields: [assignedDoctorId], references: [id], onDelete: SetNull)
  profileImage     String?         @db.Text
  notes            String?         @db.Text
  source           LeadSourceType? // how they found the clinic
  consentGiven     Boolean         @default(false)
  isVip            Boolean         @default(false)
  isActive         Boolean         @default(true)
  deletedAt        DateTime? // soft delete
  // Self-service link. When non-null this Patient has accepted an
  // invite and can log in via the PATIENT-role User pointed to here.
  // Unique because at most one Patient per User. Nullable because
  // the vast majority of patients today never sign up.
  userId           String?         @unique @db.Uuid
  user             User?           @relation("PatientUser", fields: [userId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  allergies         PatientAllergy[]
  medications       PatientMedication[]
  medicalHistory    MedicalHistory[]
  skinHistory       SkinHistory[]
  insurance         Insurance[]
  appointments      Appointment[]
  consultationNotes ConsultationNote[]
  procedures        Procedure[]
  prescriptions     Prescription[]
  labTests          LabTest[]
  documents         PatientDocument[]
  photoScores       PhotoScore[]
  invoices          Invoice[]
  insuranceClaims   InsuranceClaim[]
  patientPackages   PatientPackage[]
  communications    CommunicationLog[]
  followUps         FollowUp[]
  transcriptions    AITranscription[]
  aiSuggestions     AISuggestion[]      @relation("AISuggestionPatient")
  vitals            Vitals[]
  callLogs          CallLog[]
  convertedLeads    Lead[]
  consentForms      ConsentForm[]
  tags              PatientTag[]
  roomAllocations   RoomAllocation[]
  waitlistEntries   Waitlist[]
  invites           PatientInvite[]
  collaborationThreads CollaborationThread[] @relation("CollaborationThreadPatient")

  // v53: patientCode is per-tenant unique. Email partial unique
  // (active rows only, scoped by tenant) is enforced in raw SQL by
  // the v53 migration — Prisma can't model partial uniques.
  @@unique([tenantId, patientCode])
  @@index([phone])
  @@index([branchId])
  @@index([tenantId])
  @@index([assignedDoctorId])
  @@index([lastName, firstName])
  @@index([isActive, branchId])
  @@index([isActive, deletedAt])
  @@index([createdAt]) // "new patients this week" reports
  @@index([gender]) // demographic reports
  @@index([skinType]) // skin-category demographic reports
  @@map("patients")
}

// Invite token issued by an admin so a Patient can self-register a
// User account and link it to their existing Patient row. The token
// is a long random string (sha256 of crypto random bytes) and is
// hashed on disk — only the redeem endpoint compares against it.
//
// Lifecycle:
//   PENDING → ACCEPTED  (patient claimed it, User created)
//   PENDING → EXPIRED   (background job past expiresAt)
//   PENDING → REVOKED   (admin cancelled it)
// Terminal states never transition again.
model PatientInvite {
  id          String              @id @default(uuid()) @db.Uuid
  patientId   String              @db.Uuid
  patient     Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  // Hashed token (sha256 hex) — the plaintext is shown to the
  // admin once at creation time, then never stored.
  tokenHash   String              @unique @db.VarChar(64)
  status      PatientInviteStatus @default(PENDING)
  // 7 days from issuance by default. Past this point the redeem
  // endpoint refuses regardless of status.
  expiresAt   DateTime            @db.Timestamptz(6)
  // Channel hint for the audit trail; the actual SMS/email send
  // happens outside this row.
  channel     String?             @db.VarChar(20) // "sms" / "email" / "whatsapp"
  // Who created the invite + who redeemed it.
  createdById String              @db.Uuid
  createdBy   User                @relation("PatientInviteCreator", fields: [createdById], references: [id], onDelete: Restrict)
  acceptedAt  DateTime?           @db.Timestamptz(6)
  acceptedUserId String?          @db.Uuid
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([patientId])
  @@index([status])
  @@index([expiresAt])
  @@map("patient_invites")
}

model PatientAllergy {
  id        String   @id @default(uuid()) @db.Uuid
  patientId String   @db.Uuid
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  allergen  String   @db.VarChar(120)
  severity  Severity
  reaction  String?  @db.VarChar(200)
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@map("patient_allergies")
}

model PatientMedication {
