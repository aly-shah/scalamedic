// ---- Treatment / Package Branch availability (many-to-many) ----

/// Join table: which branches offer this treatment. UNIQUE (treatmentId,
/// branchId) prevents the same pair appearing twice. Cascade on either
/// side so the link evaporates when its parent is deleted.
model TreatmentBranch {
  id          String    @id @default(uuid()) @db.Uuid
  treatmentId String    @db.Uuid
  treatment   Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)
  branchId    String    @db.Uuid
  branch      Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([treatmentId, branchId])
  @@index([branchId])
  @@map("treatment_branches")
}

/// Join table: which branches offer this package. Same shape as
/// TreatmentBranch.
model PackageBranch {
  id        String   @id @default(uuid()) @db.Uuid
  packageId String   @db.Uuid
  package   Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  branchId  String   @db.Uuid
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([packageId, branchId])
  @@index([branchId])
  @@map("package_branches")
}

// ─────────────────────────────────────────────────────────────────
// Petty cash + daily closing — billing/accounts daily report
// ─────────────────────────────────────────────────────────────────

/// Categories for till disbursements / petty cash. Mirrors the
/// "Account / Sub-Account" column on the SkedWise Daily Sheet so the
/// daily report groups expenses cleanly. SALARY covers both monthly
/// payouts and ad-hoc advance salaries.
enum PettyCashCategory {
  SALARY
  SALARY_ADVANCE
  OFFICE_EXPENSE
  CONSUMABLES
  MAINTENANCE
  UTILITIES
  REFUND_OUT
  OTHER
}

/// One row per cash payout from the till during the day — staff salary,
/// office supplies, refund returned to patient, etc. Subtracted from
/// "Cash Received from invoices" in the day's reconciliation:
///   Opening + Cash Receipts − Petty Cash − CC Tips = Cash in Hand
///
/// `paidTo` is free text because the recipient might be a staff member,
/// a patient (for refunds), or an external vendor — we don't want to
/// tie this to user IDs that may not exist.
model PettyCashExpense {
  id          String            @id @default(uuid()) @db.Uuid
  branchId    String            @db.Uuid
  branch      Branch            @relation(fields: [branchId], references: [id], onDelete: Restrict)
  /// Day of the disbursement in clinic-time (Asia/Karachi). Stored as
  /// @db.Date so end-of-day grouping works with the same clinicDayRange
  /// helper the rest of the app uses.
  date        DateTime          @db.Date
  category    PettyCashCategory
  /// Free-text sub-account, e.g. "ali advance salary", "printer ink".
  description String            @db.VarChar(200)
  paidTo      String?           @db.VarChar(120)
  // 12,2 not 10,2 — bulk salary disbursements (rent + multiple salaries
  // logged as one petty-cash row) can exceed the 99,999 ceiling. v12
  // bumped Payment to 12,2 for the same reason; staying consistent.
  amount      Decimal           @db.Decimal(12, 2)
  notes       String?           @db.Text
  recordedById String           @db.Uuid
  recordedBy   User             @relation("PettyCashRecorded", fields: [recordedById], references: [id], onDelete: Restrict)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([branchId, date])
  @@index([date])
  @@index([category])
  @@index([recordedById]) // "petty cash entered by user X" reports
  @@map("petty_cash_expenses")
}

/// Frozen end-of-day snapshot for a (date, branch) pair. Once a day is
/// closed, the totals/JSON breakdowns persist here even if invoices or
/// payments are later edited — the saved report shows what the cash
/// drawer actually looked like at close time, not a live recompute.
///
/// Pre-close, the report is computed live from invoices+payments+
/// pettyCashExpenses. Post-close, viewers read this snapshot directly.
///
/// `salesByCategory` / `paymentsByMethod` / `expensesByCategory` /
/// `denominations` are JSON to keep the schema future-proof — adding a
/// new payment method later doesn't need a migration.
model DailyClosing {
  id          String   @id @default(uuid()) @db.Uuid
  branchId    String   @db.Uuid
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  date        DateTime @db.Date
  /// Cash brought forward from previous day's "tomorrow's till"
  /// + any morning top-up. 12,2 to match the rest of the snapshot
  /// (totalPayments etc are 12,2 — using a smaller precision here
  /// would create reconciliation dead zones at the upper end).
  openingTill Decimal  @db.Decimal(12, 2) @default(0)
  /// What the receptionist counted in the drawer. JSON keyed by
  /// denomination, e.g. {"5000":2,"1000":3,"500":1,"100":5}. Total
  /// computed in `cashCounted` for indexable reporting.
  denominations Json?
  cashCounted   Decimal  @db.Decimal(12, 2) @default(0)
  /// Everything below is the FROZEN snapshot — recomputed at close
  /// time, never updated. JSON shapes:
  ///   salesByCategory:   { Services: 23000.51, Products: 0, ... }
  ///   paymentsByMethod:  { CASH: 15000, CARD: 8000, ... }
  ///   expensesByCategory:{ SALARY: 5000, SALARY_ADVANCE: 10000, ... }
  salesByCategory    Json
  paymentsByMethod   Json
  expensesByCategory Json
  invoiceCount       Int      @default(0)
  paymentCount       Int      @default(0)
  expenseCount       Int      @default(0)
  grossSale          Decimal  @db.Decimal(12, 2) @default(0)
  netSale            Decimal  @db.Decimal(12, 2) @default(0)
  totalDiscount      Decimal  @db.Decimal(12, 2) @default(0)
  totalTax           Decimal  @db.Decimal(12, 2) @default(0)
  totalPayments      Decimal  @db.Decimal(12, 2) @default(0)
  totalExpenses      Decimal  @db.Decimal(12, 2) @default(0)
  /// Opening + cash receipts − petty cash − CC tips. The "you should
  /// have" number; compared against `cashCounted` to compute over/short.
  expectedCash       Decimal  @db.Decimal(12, 2) @default(0)
  difference         Decimal  @db.Decimal(12, 2) @default(0) // counted - expected
  remarks            String?  @db.Text
  closedById         String   @db.Uuid
  closedBy           User     @relation("DailyClosingClosedBy", fields: [closedById], references: [id], onDelete: Restrict)
  closedAt           DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // [branchId, date] composite index dropped — the @@unique below already
  // creates one with the same column order.
  @@unique([branchId, date])
  @@index([date])
  @@index([closedById]) // "closings done by user X" audit reports
  @@map("daily_closings")
}

// ─────────────────────────────────────────────────────────────────
// Role permission overrides — runtime grants/denials on top of
// the static module-definition permission grid. Each row says
// "for this (role, module, action), force the answer to `granted`."
// Absence of a row falls back to the module definition.
// ─────────────────────────────────────────────────────────────────
//
// Why this exists: the static `permissions` field on each module
// definition is the source of truth, but admins also need to flip
// permissions per role without a redeploy (e.g. give Aestheticians
// Edit on Procedures temporarily, take Delete back from Receptionists).
// /admin/roles writes here; the registry reads them on app boot and
// merges with module definitions when checking access.
//
// (role, moduleId, action) is unique — only one override per cell.
// `action` is a String, not an enum, because PermissionAction lives
// in TypeScript only — Prisma doesn't know about it. The set of
// valid values is enforced at the API layer via a zod check.
model RolePermissionOverride {
  id          String   @id @default(uuid()) @db.Uuid
  role        UserRole
  moduleId    String   @db.VarChar(60)
  /// VIEW | CREATE | EDIT | DELETE | EXPORT — enforced by a CHECK
  /// constraint at the DB level (added in the v27 migration) so a
  /// bad direct insert can't poison permission evaluation.
  action      String   @db.VarChar(20)
  granted     Boolean
  /// Audit trail: who flipped the override. Nullable + SetNull so a
  /// deleted user doesn't take their override history with them — we
  /// keep the row, just lose the "by whom" attribution. Population
  /// happens in /api/admin/role-permissions PUT from auth.user.id.
  createdById String?  @db.Uuid
  createdBy   User?    @relation("RolePermissionOverrideCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([role, moduleId, action])
  @@index([role])
  @@index([moduleId])     // "all overrides affecting MOD-PATIENT" lookups
  @@index([createdById])  // "overrides toggled by user X" audit
  @@map("role_permission_overrides")
}

// QR token printed on the thermal receipt. Opaque random string;
// resolves at /qr/[token] to either the staff visit workflow page
// (logged-in) or a public thank-you page (anonymous). No patient data
// in the URL — see lib/qr-tokens.ts for the generator.
model QrToken {
  id            String   @id @default(uuid()) @db.Uuid
  token         String   @unique @db.VarChar(32)

  appointmentId String?  @db.Uuid
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  invoiceId     String?  @db.Uuid
  invoice       Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  // Both nullable. Staff workflow refuses revoked/expired tokens; the
  // public thank-you page still renders so old printed receipts work.
  revokedAt     DateTime?
  expiresAt     DateTime?

  createdAt     DateTime @default(now())
  createdById   String?  @db.Uuid
  createdBy     User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  scans         QrScanLog[]
  review        VisitReview?

  @@index([appointmentId])
  @@index([invoiceId])
  @@index([createdById]) // "tokens issued by user X" audit
  // NB: a partial index `WHERE revokedAt IS NULL` scoped by
  // appointmentId is also created in migration v28 to speed up the
  // getOrCreateToken hot path. Prisma can't express partial indexes
  // declaratively yet, so it lives only in the migration SQL.
  @@map("qr_tokens")
}

// Patient feedback submitted from the public /review/[token] page.
// One row per token (1:1 with QrToken) — repeat scans show a
// "thanks" state instead of the form.
model VisitReview {
  id             String   @id @default(uuid()) @db.Uuid
  tokenId        String   @unique @db.Uuid
  token          QrToken  @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  rating         Int      // 1-5, CHECK enforced at DB
  feedback       String?  @db.Text
  wouldRecommend Boolean?
  // Optional display name the patient picks — never required, never
  // their real name unless they choose to type it.
  pseudonym      String?  @db.VarChar(60)
  submittedAt    DateTime @default(now())
  ipAddress      String?  @db.VarChar(45)
  userAgent      String?  @db.VarChar(300)

  @@index([submittedAt])
  @@index([rating, submittedAt(sort: Desc)]) // low-rating triage
  @@map("visit_reviews")
}

// Audit trail for every QR scan. userId null = unauthenticated public
// scan. outcome is one of STAFF_VISIT, PUBLIC_THANKYOU, REVOKED,
// EXPIRED, NOT_FOUND.
model QrScanLog {
  id         String   @id @default(uuid()) @db.Uuid
  tokenId    String   @db.Uuid
  token      QrToken  @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  userId     String?  @db.Uuid
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  scannedAt  DateTime @default(now())
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.VarChar(300)
  outcome    String   @db.VarChar(20)

  @@index([tokenId])
  @@index([userId])
  @@index([scannedAt])
  @@index([outcome, scannedAt(sort: Desc)]) // analytics: outcome × time
  @@map("qr_scan_logs")
}

// CRM-side follow-up state for website booking-form submissions.
// Joins to upstream rows by `upstreamId` (the integer id from
// drnakhodas.com/api/appointments). One row per upstream booking.
enum WebsiteBookingStatus {
  PENDING
  CONTACTED
  SCHEDULED
  CLOSED
  REJECTED
}

model WebsiteBookingOverride {
  id              String   @id @default(uuid()) @db.Uuid
  upstreamId      Int      @unique
  status          WebsiteBookingStatus @default(PENDING)
  notes           String?  @db.Text
  // FK to the lead this booking was converted into. Nullable
  // because most overrides represent in-progress follow-up rather
  // than a converted lead.
  convertedLeadId String?  @db.Uuid
  convertedLead   Lead?    @relation("WebsiteBookingConvertedLead", fields: [convertedLeadId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  updatedById     String?  @db.Uuid
  updatedBy       User?    @relation("WebsiteBookingOverrideUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([updatedAt(sort: Desc)])
  @@index([updatedById])
  // NB: a partial index on convertedLeadId (WHERE NOT NULL) lives in
  // the v30 migration SQL; Prisma can't model partial indexes.
  @@map("website_booking_overrides")
}

// CRM-side follow-up state for website contact-form submissions.
// Mirror of WebsiteBookingOverride but for the /api/messages
// upstream feed. Today the only override we record is "converted to
// a lead" (so the inbox can show ✓ View lead instead of the convert
// button). Notes are kept available for parity even though the
// Messages tab doesn't surface them yet.
model WebsiteMessageOverride {
  id              String   @id @default(uuid()) @db.Uuid
  upstreamId      Int      @unique
  notes           String?  @db.Text
  convertedLeadId String?  @db.Uuid
  convertedLead   Lead?    @relation("WebsiteMessageConvertedLead", fields: [convertedLeadId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  updatedById     String?  @db.Uuid
  updatedBy       User?    @relation("WebsiteMessageOverrideUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([updatedAt(sort: Desc)])
  @@index([updatedById])
  @@map("website_message_overrides")
}

// ═══════════════════════════════════════════════════════════════
// Multi-doctor collaboration — threaded notes between staff
// anchored to a Patient (and optionally to a specific Consultation
// Note or Procedure). Each comment can @mention other staff
// members; mentions are stored as rows for read/unread tracking.
// ═══════════════════════════════════════════════════════════════
//
// Access pattern: staff in the same tenant as the patient can read
// + write. The doctor-app's "Team chat" surface and the desktop's
// patient profile both consume the same endpoints.

model CollaborationThread {
  id                  String   @id @default(uuid()) @db.Uuid
  // Patient is the canonical access-control anchor. Required even
  // when the thread is "about" a procedure/consult — the patient
  // is who staff need permission against.
  patientId           String   @db.Uuid
  patient             Patient  @relation("CollaborationThreadPatient", fields: [patientId], references: [id], onDelete: Cascade)
  tenantId            String   @db.Uuid
  tenant              Tenant   @relation("CollaborationThreadTenant", fields: [tenantId], references: [id], onDelete: Restrict)

  // Optional sub-anchors. At most one is set at a time (CHECK
  // enforces). Null means a patient-level thread.
  consultationNoteId  String?           @db.Uuid
  consultationNote    ConsultationNote? @relation("CollaborationThreadNote", fields: [consultationNoteId], references: [id], onDelete: SetNull)
  procedureId         String?           @db.Uuid
  procedure           Procedure?        @relation("CollaborationThreadProcedure", fields: [procedureId], references: [id], onDelete: SetNull)

  title               String?  @db.VarChar(160)
  isResolved          Boolean  @default(false)

  createdById         String   @db.Uuid
  createdBy           User     @relation("CollaborationThreadCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  comments            CollaborationComment[]

  @@index([patientId])
  @@index([tenantId])
  @@index([consultationNoteId])
  @@index([procedureId])
  @@index([updatedAt(sort: Desc)])
  @@map("collaboration_threads")
}

model CollaborationComment {
  id              String   @id @default(uuid()) @db.Uuid
  threadId        String   @db.Uuid
  thread          CollaborationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId        String   @db.Uuid
  author          User     @relation("CollaborationCommentAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  body            String   @db.Text
  // Single-level threading: replies point to the parent comment.
  // Postgres doesn't have a real tree structure here; keeping it
  // single-depth keeps the UI simple and the query cost flat.
  parentCommentId String?  @db.Uuid
  parentComment   CollaborationComment?  @relation("CollaborationCommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies         CollaborationComment[] @relation("CollaborationCommentReplies")

  // Track soft-edits — body diff history isn't kept (single text
  // overwrite); the timestamp lets the UI show "edited 2 min ago".
  editedAt        DateTime? @db.Timestamptz(6)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  mentions        CollaborationMention[]

  @@index([threadId, createdAt])
  @@index([authorId])
  @@index([parentCommentId])
  @@map("collaboration_comments")
}

model CollaborationMention {
  id          String   @id @default(uuid()) @db.Uuid
  commentId   String   @db.Uuid
  comment     CollaborationComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  // The user being mentioned. They get the unread badge.
  userId      String   @db.Uuid
  user        User     @relation("CollaborationMentionTarget", fields: [userId], references: [id], onDelete: Cascade)
  readAt      DateTime? @db.Timestamptz(6)
  createdAt   DateTime  @default(now())

  // One row per (comment, user) — mentioning the same person
  // twice in one comment dedups via the unique index.
  @@unique([commentId, userId])
  @@index([userId, readAt])
  @@map("collaboration_mentions")
}

// Session revocation — a JWT's `jti` here is rejected by the auth
// middleware even if the token's signature + expiresAt are still
// valid. Logout adds the jti; the desktop "Sign out everywhere"
// (future) can revoke an entire user's active set in one shot.
model RevokedSession {
  jti        String    @id @db.VarChar(64)
  userId     String    @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime  @db.Timestamptz(6)
  reason     String?   @db.VarChar(40)
  revokedAt  DateTime  @default(now()) @db.Timestamptz(6)

  @@index([userId])
  @@index([expiresAt])
  @@map("revoked_sessions")
}

// v55 — ICD-10 master catalogue. Curated subset of dermatology and
// common comorbidity codes, seeded by the v55 migration. The
// canonical source is WHO ICD-10 2019; codes here use the dotted
// form (e.g. "L70.0"). `description` is the human-friendly name
// shown in the picker; `category` groups codes for easier browsing
// (e.g. "Disorders of skin appendages").
//
// Notes are stored in `consultation_notes.icd10Codes` as a String[]
// array; the FK relationship to this table is checked at the route
// layer rather than the DB tier (Postgres array FKs are awkward and
// the catalogue is read-only in normal use).
model ICD10Code {
  code        String   @id @db.VarChar(10) // e.g. "L70.0"
  description String   @db.VarChar(200)
  category    String?  @db.VarChar(120)
  /** When true, suggested first in the picker — used to surface
   *  high-frequency codes (acne, eczema, psoriasis). */
  isCommon    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isCommon, isActive])
  @@map("icd10_codes")
}
