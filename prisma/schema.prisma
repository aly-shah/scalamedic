// ---- Clinical ----

model ConsultationNote {
  id                String      @id @default(uuid()) @db.Uuid
  appointmentId     String      @db.Uuid
  appointment       Appointment @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  patientId         String      @db.Uuid
  patient           Patient     @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctorId          String      @db.Uuid
  doctor            User        @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  chiefComplaint    String?     @db.Text
  symptoms          String?     @db.Text
  examination       String?     @db.Text
  skinAssessment    String?     @db.Text // dermatology specific
  affectedAreas     String[] // ["Face", "Neck", ...]
  conditionSeverity Severity?
  diagnosis         String?     @db.Text
  differentialDx    String?     @db.Text // differential diagnosis
  // v55 — Structured diagnosis codes. Array of ICD-10 codes (e.g.
  // ["L70.0", "L81.1"]); first element is the primary diagnosis.
  // The free-text `diagnosis` field stays for narrative — codes
  // sit alongside it for analytics and claim-coding workflows.
  icd10Codes        String[]    @default([])
  treatmentPlan     String?     @db.Text
  advice            String?     @db.Text
  internalNotes     String?     @db.Text // not visible to patient
  followUpDate      DateTime?   @db.Date
  followUpNotes     String?     @db.Text
  isSigned          Boolean     @default(false)
  signedAt          DateTime?
  // E-signature integrity primitives. signedById captures who signed
  // (separate from doctorId; clinics with locum cover may have a
  // signer who isn't the original doctor). signedContentHash binds
  // the signature to the exact content at sign time — a SHA-256 of
  // the canonicalized clinical fields. amendmentReason is required
  // when an already-signed note is changed (and clears signature).
  signedById        String?     @db.Uuid
  signedBy          User?       @relation("ConsultationNoteSigner", fields: [signedById], references: [id], onDelete: SetNull)
  signedContentHash String?     @db.VarChar(64) // SHA-256 hex
  amendmentReason   String?     @db.Text
  revisionCount     Int         @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  revisions         ConsultationNoteRevision[] @relation("ConsultationNoteRevisions")
  collaborationThreads CollaborationThread[] @relation("CollaborationThreadNote")

  @@index([patientId])
  @@index([appointmentId])
  @@index([doctorId, createdAt])
  @@index([appointmentId, createdAt])
  @@index([signedById])
  @@map("consultation_notes")
}

// Immutable revisions of a consultation note. Every edit creates a
// row capturing the prior state; the live row in `consultation_notes`
// always represents the current state. Signatures bind to the
// content at signing time (see signedContentHash on the parent), so
// a tamper at the DB tier becomes detectable by re-hashing.
model ConsultationNoteRevision {
  id                String    @id @default(uuid()) @db.Uuid
  consultationNoteId String   @db.Uuid
  consultationNote  ConsultationNote @relation("ConsultationNoteRevisions", fields: [consultationNoteId], references: [id], onDelete: Cascade)
  revisionNumber    Int       // monotonic per consultationNoteId, starting at 1
  // Frozen JSON snapshot of the note's clinical fields at the time
  // this revision was created. Read-only; never updated.
  snapshot          Json
  // Whether the note was signed *as captured in this revision*
  // (i.e. at the moment we snapshotted prior state). Signatures may
  // not survive into subsequent revisions if an amendment cleared
  // them.
  wasSigned         Boolean   @default(false)
  signedAtSnapshot  DateTime? @db.Timestamptz(6)
  signedByIdSnapshot String?  @db.Uuid
  signedContentHashSnapshot String? @db.VarChar(64)
  // Why this revision was created. Mandatory amendments to a signed
  // note must explain themselves; auto-revisions on first save can
  // omit it.
  amendmentReason   String?   @db.Text
  // Who authored the change that produced this revision (i.e. who
  // edited or signed). Nullable on legacy data; required for new rows
  // via the route layer.
  authorId          String?   @db.Uuid
  author            User?     @relation("ConsultationNoteRevisionAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt         DateTime  @default(now())

  @@unique([consultationNoteId, revisionNumber])
  @@index([consultationNoteId])
  @@index([authorId])
  @@map("consultation_note_revisions")
}

model Treatment {
  id                String            @id @default(uuid()) @db.Uuid
  name              String            @db.VarChar(150)
  code              String?           @unique @db.VarChar(20) // TRT-001
  category          TreatmentCategory
  // Tax bucket for invoicing — see TaxCategory enum + lib/tax-rates.ts.
  // Backfilled to MEDICAL on existing rows; admin can reclassify.
  taxCategory       TaxCategory       @default(MEDICAL)
  description       String?           @db.Text
  duration          Int // minutes
  basePrice         Decimal           @db.Decimal(10, 2)
  preInstructions   String?           @db.Text
  postInstructions  String?           @db.Text
  contraindications String?           @db.Text
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  procedures        Procedure[]
  packageTreatments PackageTreatment[]
  invoiceItems      InvoiceItem[]
  // Booked appointments that picked this treatment at booking time.
  appointments      Appointment[]      @relation("AppointmentTreatment")
  // Branch availability — empty = available everywhere is NOT the rule;
  // every treatment must have at least one row (UI enforces). v24 backfill
  // seeded each treatment with every branch.
  branches          TreatmentBranch[]
  protocols         ProcedureProtocol[] @relation("TreatmentProtocols")

  @@index([category])
  @@index([category, isActive]) // "active LASER" / "active FACIAL" lists
  @@index([taxCategory])
  @@map("treatments")
}

model Procedure {
  id            String      @id @default(uuid()) @db.Uuid
  appointmentId String      @db.Uuid
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  patientId     String      @db.Uuid
  patient       Patient     @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctorId      String      @db.Uuid
  doctor        User        @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  treatmentId   String      @db.Uuid
  treatment     Treatment   @relation(fields: [treatmentId], references: [id], onDelete: Restrict)
  areasTreated  String[]
  settings      Json? // laser power, peel %, etc.
  notes         String?     @db.Text
  outcome       String?     @db.Text
  complications String?     @db.Text
  beforeImages  String[]
  afterImages   String[]
  consentSigned Boolean     @default(false)
  // E-consent provenance. Captured when the procedure is started:
  // signedAt = wall time the staff member witnessed the patient
  // signing; signedById = the witnessing staff member's user id.
  // Both required when consentSigned=true (see CHECK in v40).
  consentSignedAt   DateTime? @db.Timestamptz(6)
  consentSignedById String?   @db.Uuid
  consentSignedBy   User?     @relation("ProcedureConsentWitness", fields: [consentSignedById], references: [id], onDelete: SetNull)
  // Optional protocol binding. When a procedure is initiated from
  // a ProcedureProtocol, the protocolId records which template was
  // used and protocolSnapshot freezes the protocol's contents at
  // that moment — so future protocol edits don't rewrite history.
  protocolId       String?            @db.Uuid
  protocol         ProcedureProtocol? @relation(fields: [protocolId], references: [id], onDelete: SetNull)
  protocolSnapshot Json?
  performedAt   DateTime?   @db.Timestamptz(6)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([patientId])
  @@index([treatmentId])
  @@index([performedAt])
  @@index([appointmentId])
  @@index([protocolId])
  @@index([consentSignedById])
  @@index([doctorId])
  @@index([patientId, performedAt(sort: Desc)]) // patient procedure timeline
  collaborationThreads CollaborationThread[] @relation("CollaborationThreadProcedure")

  @@index([doctorId, performedAt(sort: Desc)])  // doctor's recent work
  @@index([consentSigned]) // consent-compliance audit
  @@map("procedures")
}

// Reusable template for in-clinic procedures (HydraFacial, PRP,
// Carbon Laser, peels, hair restoration, etc.). When a Procedure
// is initiated from a protocol, the consent text, expected photo
// angles, machine-setting defaults, and aftercare guidance pre-
// fill — and the protocol payload at that moment is frozen onto
// the Procedure as `protocolSnapshot` so future template edits
// don't rewrite the historical record.
//
// Tenant-scoped (each clinic chain has its own protocols). Branch
// is optional — null means "available across every branch in the
// tenant".
model ProcedureProtocol {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branchId    String?  @db.Uuid
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)

  // Display name shown in pickers (e.g. "HydraFacial — Standard").
  name        String   @db.VarChar(120)
  // Free-form description for staff training.
  description String?  @db.Text

  // Optional canonical Treatment this protocol attaches to. Setting
  // it lets the Procedure form auto-suggest this protocol when the
  // doctor picks the matching treatment. SetNull on treatment delete
  // — the protocol survives but unbinds.
  treatmentId String?  @db.Uuid
  treatment   Treatment? @relation("TreatmentProtocols", fields: [treatmentId], references: [id], onDelete: SetNull)

  // Patient-facing consent text, rendered on the consent screen
  // before the patient's signature. Markdown allowed; the UI
  // converts it.
  consentTemplate String? @db.Text

  // Photo angles the staff is expected to capture. Examples:
  // ["Face front", "Left profile", "Right profile"]. Empty array
  // is allowed (no photos required).
  requiredBeforePhotos String[]
  requiredAfterPhotos  String[]

  // Default machine settings. Free-shape JSON keyed by setting
  // name (e.g. {"laserPower": 12, "spotSize": 5}). The UI presents
  // them as editable defaults; whatever the operator actually uses
  // is captured on the Procedure.
  machineSettings Json?

  // Printed aftercare instructions the patient takes home. Same
  // markdown convention as consentTemplate.
  aftercareInstructions String? @db.Text

  // Recommended follow-up booking offset. Null means no built-in
  // suggestion — staff can still book one manually.
  suggestedFollowUpDays Int?

  // Optional Rx kit reference — points at a key from the doctor-
  // app's RX_TEMPLATES map. Loose coupling on purpose; renaming
  // a kit just orphans the link rather than breaking the row.
  rxKitName     String? @db.VarChar(60)

  // Estimated wall time the procedure typically takes. Drives
  // appointment booking durations and queue ETA forecasts.
  estimatedDurationMinutes Int?

  // Bumped on every edit. Old Procedure rows retain their frozen
  // snapshot regardless; this is just a human-readable revision
  // marker on the live row.
  version     Int      @default(1)
  isActive    Boolean  @default(true)

  createdById String   @db.Uuid
  createdBy   User     @relation("ProcedureProtocolCreator", fields: [createdById], references: [id], onDelete: Restrict)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  procedures  Procedure[]

  @@index([tenantId])
  @@index([branchId])
  @@index([treatmentId])
  @@index([isActive, tenantId])
  @@map("procedure_protocols")
}

model Prescription {
  id            String       @id @default(uuid()) @db.Uuid
  patientId     String       @db.Uuid
  patient       Patient      @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctorId      String       @db.Uuid
  doctor        User         @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  // Optional FK detaches on appointment deletion so prescription history
  // survives cleanup of the source appointment row.
  appointmentId String?      @db.Uuid
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  notes         String?      @db.Text
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  items PrescriptionItem[]

  @@index([patientId])
  @@index([doctorId])
  @@index([appointmentId])
  @@index([doctorId, createdAt])
  @@index([patientId, createdAt(sort: Desc)]) // patient Rx timeline
  @@map("prescriptions")
}

model PrescriptionItem {
  id             String       @id @default(uuid()) @db.Uuid
  prescriptionId String       @db.Uuid
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicineName   String       @db.VarChar(200)
  dosage         String?      @db.VarChar(100)
  frequency      String?      @db.VarChar(60) // OD, BD, TDS, QDS
  duration       String?      @db.VarChar(60)
  route          String?      @db.VarChar(40) // Topical, Oral, etc.
  instructions   String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([prescriptionId])
  @@map("prescription_items")
}

model LabTest {
  id            String        @id @default(uuid()) @db.Uuid
  patientId     String        @db.Uuid
  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctorId      String        @db.Uuid
  doctor        User          @relation("DoctorLabTests", fields: [doctorId], references: [id], onDelete: Restrict)
  // Structured per-analyte rows live in lab_test_results (one row
  // per analyte). The legacy `results` JSON / `notes` text fields
  // stay for unstructured / narrative results.
  resultRows    LabTestResult[]
  appointmentId String?       @db.Uuid
  appointment   Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  testName      String        @db.VarChar(150)
  testCode      String?       @db.VarChar(20)
  status        LabTestStatus @default(REQUESTED)
  priority      Priority      @default(NORMAL)
  results       Json?
  technician    String?       @db.VarChar(120)
  collectedAt   DateTime?     @db.Timestamptz(6)
  completedAt   DateTime?     @db.Timestamptz(6)
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([patientId])
  @@index([status])
  @@index([doctorId, createdAt])
  @@index([appointmentId])
  @@index([priority])     // "urgent first" lab queue sort
  @@index([completedAt])  // "completed in last 7 days" analytics
  @@index([patientId, createdAt(sort: Desc)]) // patient lab timeline
  @@map("lab_tests")
}

// Structured per-analyte result rows. One LabTest can have many
// (e.g. a CBC has Hb, WBC, Platelets, MCV…). The fields support
// both numeric results (Hb = 12.5 g/dL, range 12.0–16.0) and
// categorical ones (HBsAg = "Negative", reference = "Negative").
//
// `isAbnormal` is set explicitly by the lab tech / route logic
// rather than recomputed at read time — labs sometimes flag based
// on context (delta vs prior, age/sex-specific ranges) that the
// numeric range alone doesn't capture.
model LabTestResult {
  id          String   @id @default(uuid()) @db.Uuid
  labTestId   String   @db.Uuid
  labTest     LabTest  @relation(fields: [labTestId], references: [id], onDelete: Cascade)

  /// Display name of the analyte. Free-text so the lab tech can
  /// type "Hemoglobin" or "Hb" — UI sorts on `displayOrder` not
  /// alphabetical so panels render in clinically expected order.
  analyte     String   @db.VarChar(120)
  /// Optional code (LOINC, local catalog, NABL panel id…). Loose
  /// type — different markets use different code systems.
  code        String?  @db.VarChar(40)

  /// What the lab tech entered, verbatim. Always present so the
  /// printed report renders even when valueNumeric is null
  /// (categorical / qualitative results).
  value       String   @db.VarChar(60)
  /// Parsed numeric value when applicable. Null for categorical
  /// results. Used for reference-range comparisons and trending.
  valueNumeric Decimal? @db.Decimal(14, 4)
  unit        String?  @db.VarChar(40)

  /// Numeric reference range (when applicable). Either both or
  /// neither set; route-level CHECK enforces.
  referenceLow  Decimal? @db.Decimal(14, 4)
  referenceHigh Decimal? @db.Decimal(14, 4)
  /// Free-text reference for categorical results, e.g. "Negative".
  referenceText String? @db.VarChar(80)

  /// Explicit abnormal flag. Lab tech sets it; not recomputed at
  /// read time so age/sex/delta-based judgments survive.
  isAbnormal  Boolean  @default(false)
  /// Optional severity flag — H, L, HH, LL, A. Display-only.
  flag        String?  @db.VarChar(4)

  /// Order within the result panel (lab tech can drag-reorder when
  /// the entry UI supports it). Defaults to 0; multiple rows can
  /// share an order.
  displayOrder Int     @default(0)

  notes       String?  @db.Text

  enteredById String?  @db.Uuid
  enteredBy   User?    @relation("LabTestResultEnterer", fields: [enteredById], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([labTestId, displayOrder])
  @@index([labTestId, isAbnormal])
  @@map("lab_test_results")
}

model PatientDocument {
  id           String       @id @default(uuid()) @db.Uuid
  patientId    String       @db.Uuid
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Restrict)
  name         String       @db.VarChar(200)
  type         DocumentType
  fileUrl      String       @db.Text
  fileSize     Int?
  mimeType     String?      @db.VarChar(60)
  uploadedById String       @db.Uuid
  uploadedBy   User         @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  notes        String?      @db.Text
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // v56 — AI photo scoring. At most one current scoring row per
  // document; re-scoring replaces it. Cascade so a deleted document
  // takes its score with it.
  photoScore   PhotoScore?

  @@index([patientId])
  @@index([patientId, type])
  @@index([uploadedById])
  @@index([createdAt]) // chronological "recent uploads" listing
  @@map("patient_documents")
}

// v56 — AI photo scoring (Tier 4.3).
//
// One row per scored PatientDocument. Stores the AI's structured
// dermatology assessment plus model+prompt provenance so a future
// audit can reconstruct what was analysed and by which model. Re-
// scoring replaces the row (one-to-one with the document).
//
// Doctor decision flow (accept/reject) is intentionally NOT modelled
// here in v1 — the score is informational, the doctor reads it and
// uses their own judgment. Add a status enum later if a workflow
// emerges.
model PhotoScore {
  id              String   @id @default(uuid()) @db.Uuid
  documentId      String   @unique @db.Uuid
  document        PatientDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  patientId       String   @db.Uuid
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  /// Recognised condition (e.g. "Acne vulgaris", "Melasma"). Free
  /// text from the model — not bound to ICD-10. Doctor maps to a
  /// real diagnosis if they want to commit it.
  condition       String?  @db.VarChar(120)
  /// Coarse severity. Free string so different conditions can pick
  /// scales appropriate to them (IGA mild/moderate/severe for acne,
  /// MASI bands for melasma, etc.).
  severity        String?  @db.VarChar(20)
  /// Approximate lesion / mole / patch count if countable.
  lesionCount     Int?
  /// Body area visible in the photo, as identified by the model.
  bodyArea        String?  @db.VarChar(120)
  /// Free-form findings narrative — what the model saw.
  findings        String?  @db.Text
  /// Suggested next steps. Always read as suggestions, not orders.
  recommendations String?  @db.Text
  /// Self-reported model confidence 0-100. May be null if the model
  /// declined to estimate.
  confidence      Int?

  /// Provenance — exact model + prompt version that produced this row.
  modelId         String   @db.VarChar(60)
  promptVersion   String   @db.VarChar(60)
  /// Who triggered the scoring run. Restrict so a deleted user
  /// doesn't orphan the audit trail.
  scoredById      String   @db.Uuid
  scoredBy        User     @relation(fields: [scoredById], references: [id], onDelete: Restrict)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([patientId, createdAt(sort: Desc)])
  @@index([scoredById])
  @@map("photo_scores")
}

// ---- Billing ----

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  // v53: invoiceNumber is per-tenant unique (composite below).
  invoiceNumber String        @db.VarChar(30) // INV-2026-0001
  patientId     String        @db.Uuid
  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Restrict)
  // appointmentId is optional and detaches on appointment deletion (SetNull)
  // so historic invoices remain reproducible if the source appointment is purged.
  appointmentId String?       @db.Uuid
  appointment   Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  branchId      String        @db.Uuid
  branch        Branch        @relation(fields: [branchId], references: [id], onDelete: Restrict)
  // v53: denormalized tenant FK; trigger keeps it == branch.tenantId.
  tenantId      String        @db.Uuid
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  // (14,2) covers multi-treatment package totals that can hit 8 digits.
  subtotal      Decimal       @db.Decimal(14, 2)
  discount      Decimal       @default(0) @db.Decimal(14, 2)
  discountType  DiscountType  @default(FIXED)
  tax           Decimal       @default(0) @db.Decimal(14, 2)
  total         Decimal       @db.Decimal(14, 2)
  amountPaid    Decimal       @default(0) @db.Decimal(14, 2)
  balanceDue    Decimal       @default(0) @db.Decimal(14, 2)
  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime?     @db.Date
  notes         String?       @db.Text
  createdById   String        @db.Uuid
  createdBy     User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items           InvoiceItem[]
  payments        Payment[]
  refunds         Refund[]
  patientPackages PatientPackage[]
  qrTokens        QrToken[]
  insuranceClaims InsuranceClaim[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([patientId])
  @@index([status])
  @@index([branchId])
  @@index([dueDate, status])
  @@index([createdAt])
  @@index([appointmentId])
  @@index([createdById])
  @@index([patientId, createdAt(sort: Desc)]) // patient history page (newest first)
  @@index([patientId, status]) // outstanding invoices per patient
  @@index([branchId, createdAt(sort: Desc)]) // branch-scoped revenue reports
  @@map("invoices")
}

model Payment {
  id            String            @id @default(uuid()) @db.Uuid
  invoiceId     String            @db.Uuid
  invoice       Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  amount        Decimal           @db.Decimal(10, 2)
  method        PaymentMethodType
  reference     String?           @db.VarChar(100)
  status        PaymentStatusType @default(PENDING)
  processedById String            @db.Uuid
  processedBy   User              @relation(fields: [processedById], references: [id], onDelete: Restrict)
  processedAt   DateTime?
  notes         String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([invoiceId])
  @@index([method])
  @@index([status])
  @@index([processedById])
  @@index([processedAt])
  @@index([invoiceId, status]) // payment-status filter on an invoice's history
  @@map("payments")
}

// ---- Packages ----

model Package {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @db.VarChar(120)
  description    String?  @db.Text
  price          Decimal  @db.Decimal(10, 2)
  validityDays   Int
  maxRedemptions Int? // null = unlimited
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  treatments      PackageTreatment[]
  patientPackages PatientPackage[]
  invoiceItems    InvoiceItem[]
  // Branch availability — same model as TreatmentBranch.
  branches        PackageBranch[]

  @@index([isActive])
  @@index([createdAt])
  @@map("packages")
}

model InvoiceItem {
  id          String     @id @default(uuid()) @db.Uuid
  invoiceId   String     @db.Uuid
  invoice     Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  // Catalog FKs use Restrict — treatments/products/packages must be soft-
  // deactivated (isActive=false) rather than hard-deleted so receipts stay
  // reproducible. A DB CHECK in the v11 migration also enforces at-most-one
  // catalog link per line item.
  treatmentId String?    @db.Uuid
  treatment   Treatment? @relation(fields: [treatmentId], references: [id], onDelete: Restrict)
  productId   String?    @db.Uuid
  product     Product?   @relation(fields: [productId], references: [id], onDelete: Restrict)
  packageId   String?    @db.Uuid
  package     Package?   @relation(fields: [packageId], references: [id], onDelete: Restrict)
  description String     @db.VarChar(300)
  quantity    Int        @default(1)
  unitPrice   Decimal    @db.Decimal(10, 2)
  discount    Decimal    @default(0) @db.Decimal(10, 2)
  tax         Decimal    @default(0) @db.Decimal(10, 2)
  total       Decimal    @db.Decimal(10, 2)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([invoiceId])
  @@index([treatmentId])
  @@index([productId])
  @@index([packageId])
  @@map("invoice_items")
}

model PackageTreatment {
  id          String     @id @default(uuid()) @db.Uuid
  packageId   String     @db.Uuid
  package     Package    @relation(fields: [packageId], references: [id], onDelete: Cascade)
  treatmentId String?    @db.Uuid
  treatment   Treatment? @relation(fields: [treatmentId], references: [id], onDelete: SetNull)
  name        String     @db.VarChar(120) // denormalized snapshot
  sessions    Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([packageId, treatmentId]) // one Treatment row per Package
  @@index([packageId])
  @@index([treatmentId])
  @@map("package_treatments")
}

model PatientPackage {
  id                String        @id @default(uuid()) @db.Uuid
  patientId         String        @db.Uuid
  patient           Patient       @relation(fields: [patientId], references: [id], onDelete: Restrict)
  packageId         String        @db.Uuid
  package           Package       @relation(fields: [packageId], references: [id], onDelete: Restrict)
  purchaseDate      DateTime      @db.Date
  expiryDate        DateTime      @db.Date
  remainingSessions Json // {treatmentName: sessionsLeft}
  status            PackageStatus @default(ACTIVE)
  invoiceId         String?       @db.Uuid
  invoice           Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([patientId])
  @@index([status])
  @@index([invoiceId])
  @@index([packageId])
  @@index([expiryDate]) // "packages expiring this week" widget
  @@index([purchaseDate]) // "packages sold this month" report
  @@map("patient_packages")
}

// ---- Call Center ----

model Lead {
  id                 String         @id @default(uuid()) @db.Uuid
  name               String         @db.VarChar(120)
  phone              String         @db.VarChar(32)
  email              String?        @db.VarChar(180)
  source             LeadSourceType
  status             LeadStatusType @default(NEW)
  interest           String?        @db.VarChar(200) // what they asked about
  assignedToId       String         @db.Uuid
  assignedTo         User           @relation(fields: [assignedToId], references: [id], onDelete: Restrict)
  branchId           String         @db.Uuid
  branch             Branch         @relation(fields: [branchId], references: [id], onDelete: Restrict)
  notes              String?        @db.Text
  convertedPatientId String?        @db.Uuid
  convertedPatient   Patient?       @relation(fields: [convertedPatientId], references: [id], onDelete: SetNull)
  callbackDate       DateTime?      @db.Timestamptz(6)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  callLogs               CallLog[]
  communications         CommunicationLog[]
  websiteBookingsConverted WebsiteBookingOverride[] @relation("WebsiteBookingConvertedLead")
  websiteMessagesConverted WebsiteMessageOverride[] @relation("WebsiteMessageConvertedLead")

  @@index([phone])
  @@index([status])
  @@index([assignedToId])
  @@index([branchId, status])
  @@index([convertedPatientId])
  @@index([callbackDate]) // "callbacks due today" dashboard widget
  @@index([source]) // lead-source breakdown reports
  @@index([status, createdAt(sort: Desc)]) // "new leads this week" reports
  @@map("leads")
}

model CallLog {
  id          String      @id @default(uuid()) @db.Uuid
  leadId      String?     @db.Uuid
  lead        Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)
  patientId   String?     @db.Uuid
  patient     Patient?    @relation(fields: [patientId], references: [id], onDelete: Restrict)
  userId      String      @db.Uuid
  user        User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  type        Direction
  duration    Int? // seconds
  notes       String?     @db.Text
  outcome     CallOutcome
  // Raw caller id as reported by the phone / dialer. Preserved even when the
  // call doesn't match any patient/lead so we can always show the real number
  // and re-match later if the patient record is added after the fact.
  phone       String?     @db.VarChar(32)
  // Display name the device had for this number at call time (CACHED_NAME from
  // Android's CallLog). Lets the dashboard show "Ali Khan · +92300…" without
  // requiring a patient match.
  contactName String?     @db.VarChar(100)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([leadId])
  @@index([patientId])
  @@index([userId, createdAt])
  @@index([phone]) // dialer/Android bridge looks up history by raw caller id
  @@index([outcome]) // call-outcome reports
  @@index([outcome, createdAt(sort: Desc)]) // outcome-over-time reports
  @@map("call_logs")
}

model CommunicationLog {
  id        String      @id @default(uuid()) @db.Uuid
  // Both patient + sender are nullable — inbound from an unknown
  // number arrives before any human links it to a patient. The DB
  // CHECK enforces that one of (patientId / leadId / phone) is set.
  patientId String?     @db.Uuid
  patient   Patient?    @relation(fields: [patientId], references: [id], onDelete: Restrict)
  // Optional lead linkage for inbound that matches a known prospect.
  leadId    String?     @db.Uuid
  lead      Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)
  // Raw phone for unmatched inbound — preserved so a future patient
  // record can be back-linked.
  phone     String?     @db.VarChar(32)
  type      CommChannel
  direction Direction
  subject   String?     @db.VarChar(200)
  content   String?     @db.Text
  sentById  String?     @db.Uuid
  sentBy    User?       @relation(fields: [sentById], references: [id], onDelete: Restrict)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([patientId, type]) // covers [patientId] prefix
  @@index([patientId, createdAt]) // patient timeline queries
  @@index([createdAt]) // recent communications dashboards
  @@index([sentById])
  @@index([type, createdAt]) // channel-specific feeds (e.g. "WhatsApp today")
  @@index([direction]) // inbound vs outbound feeds
  @@index([leadId])
  // The migration also creates partial indexes on phone and leadId
  // and a (type, direction, createdAt DESC) composite for the
  // recent-inbound feed — Prisma can't model partial indexes so they
  // live in the migration SQL only.
  @@map("communication_logs")
}

// ---- Follow-ups ----

model FollowUp {
  id            String         @id @default(uuid()) @db.Uuid
  patientId     String         @db.Uuid
  patient       Patient        @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctorId      String         @db.Uuid
  doctor        User           @relation("DoctorFollowUps", fields: [doctorId], references: [id], onDelete: Restrict)
  appointmentId String?        @db.Uuid
  appointment   Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  dueDate       DateTime       @db.Date
  reason        String         @db.Text
  status        FollowUpStatus @default(PENDING)
  notes         String?        @db.Text
  completedAt   DateTime?      @db.Timestamptz(6)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([patientId])
  @@index([status])
  @@index([doctorId, dueDate, status]) // doctor's pending follow-ups; covers [doctorId] prefix
  @@index([dueDate, status]) // global dashboard: all follow-ups due today; covers [dueDate] prefix
  @@index([appointmentId])
  @@map("follow_ups")
}

// ---- AI ----

model AITranscription {
  id             String              @id @default(uuid()) @db.Uuid
  appointmentId  String              @db.Uuid
  appointment    Appointment         @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  patientId      String              @db.Uuid
  patient        Patient             @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctorId       String              @db.Uuid
  doctor         User                @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  rawTranscript  String?             @db.Text
  structuredNote Json?
  summary        String?             @db.Text
  status         TranscriptionStatus @default(RECORDING)
  duration       Int? // seconds
  language       String?             @db.VarChar(10) // "en", "ur"
  completedAt    DateTime?           @db.Timestamptz(6)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  // Suggestions emitted from this transcription (e.g. proposed
  // medications, labs, follow-ups). Nullable because not every
  // transcription produces actionable proposals.
  suggestions    AISuggestion[]      @relation("AISuggestionTranscription")

  @@index([appointmentId])
  @@index([patientId])
  @@index([status])
  @@index([doctorId])
  @@index([completedAt]) // recent-transcriptions list
  @@map("ai_transcriptions")
}

// AI suggestion audit log — every AI-generated proposal that
// reaches the doctor as a clickable affordance (e.g. Ambient
// Scribe v2 "Add this medication?" / "Order this lab?") is recorded
// here BEFORE the doctor sees it, with the prompt + model used.
// When the doctor accepts or rejects, the row is updated. Why this
// exists: malpractice defense + model-quality monitoring + the
// ability to retroactively answer "what did the AI tell the doctor
// six months ago when it was on a different model?"
//
// The accepted/rejected decision is captured as a status enum so
// "no action yet" is a distinct state from rejection.
model AISuggestion {
  id             String          @id @default(uuid()) @db.Uuid
  // What kind of proposal: medication on Rx, lab order, follow-up
  // booking, structured-note field. The string keeps it open for
  // additions without an enum migration.
  kind           AISuggestionKind
  // Optional links to the things this suggestion was about / led
  // to. Nullable because the patient/appointment may not be set on
  // ad-hoc dictation. If the doctor accepts, `acceptedEntityType` +
  // `acceptedEntityId` capture the artifact that was created
  // (e.g. PrescriptionItem id, LabTest id) so we can trace from
  // suggestion → real clinical record.
  patientId      String?         @db.Uuid
  patient        Patient?        @relation("AISuggestionPatient", fields: [patientId], references: [id], onDelete: SetNull)
  appointmentId  String?         @db.Uuid
  appointment    Appointment?    @relation("AISuggestionAppointment", fields: [appointmentId], references: [id], onDelete: SetNull)
  // Which doctor saw this suggestion (the one who'd accept or
  // reject). Distinct from the transcription's doctorId because in
  // theory a supervising doctor could be acting on a junior's
  // dictation.
  doctorId       String          @db.Uuid
  doctor         User            @relation("AISuggestionDoctor", fields: [doctorId], references: [id], onDelete: Restrict)

  // What the AI said. Free-shape JSON so each kind can carry its
  // own fields (medicineName + dosage for MEDICATION, testName +
  // testCode for LAB, reason + days for FOLLOWUP, etc.).
  payload        Json

  // Provenance — exactly which model + prompt produced this. Both
  // are required for retroactive defensibility. promptVersion is a
  // string we manage in code (e.g. "ambient-v1.0").
  modelId        String          @db.VarChar(80)  // e.g. "gpt-4o-mini"
  promptVersion  String          @db.VarChar(40)  // e.g. "ambient-scribe-v1"

  // Optional FK back to the transcription that produced this. Some
  // suggestions arrive from non-transcription paths (text-only AI
  // structuring) — those leave this null.
  transcriptionId String?        @db.Uuid
  transcription  AITranscription? @relation("AISuggestionTranscription", fields: [transcriptionId], references: [id], onDelete: SetNull)

  // Decision lifecycle. PENDING by default; transitions to
  // ACCEPTED / REJECTED / EXPIRED based on the doctor's action.
  status         AISuggestionStatus @default(PENDING)
  decidedAt      DateTime?       @db.Timestamptz(6)
  decidedById    String?         @db.Uuid
  decidedBy      User?           @relation("AISuggestionDecider", fields: [decidedById], references: [id], onDelete: SetNull)

  // When the doctor accepts and the system creates a real
  // artifact, capture what was created so we can later say "this
  // PrescriptionItem originated as AI suggestion X". Both nullable
  // because rejected/expired suggestions never produce an artifact.
  acceptedEntityType String?      @db.VarChar(40)  // e.g. "PrescriptionItem"
  acceptedEntityId   String?      @db.Uuid

  rejectionReason String?        @db.Text

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([doctorId, createdAt(sort: Desc)])
  @@index([patientId])
  @@index([appointmentId])
  @@index([transcriptionId])
  @@index([status])
  @@index([kind, status])
  @@map("ai_suggestions")
}

enum AISuggestionKind {
  MEDICATION
  LAB
  FOLLOWUP
  PROCEDURE
  NOTE_FIELD
  DIAGNOSIS_HINT
}

enum AISuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

// ---- Notifications ----

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String           @db.VarChar(200)
  message   String           @db.Text
  type      NotificationType
  isRead    Boolean          @default(false)
  link      String?          @db.Text
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([type]) // "all SYSTEM notifications" admin filter
  @@map("notifications")
}

// ---- Vitals ----
// (Renamed from Triage in v66. The table stores patient vitals —
// BP, pulse, temperature, weight, BMI, SpO₂, urgency flag — the
// "triage" label was a misnomer from an early prototype.)

model Vitals {
  id               String       @id @default(uuid()) @db.Uuid
  patientId        String       @db.Uuid
  patient          Patient      @relation(fields: [patientId], references: [id], onDelete: Restrict)
  appointmentId    String?      @db.Uuid
  appointment      Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  temperature      Float?
  temperatureUnit  String       @default("C") @db.VarChar(2) // "C" or "F"
  systolicBP       Int?
  diastolicBP      Int?
  heartRate        Int?
  respiratoryRate  Int?
  weight           Float? // kg
  height           Float? // cm
  bmi              Float?
  oxygenSaturation Float?
  painLevel        Int? // 0-10
  notes            String?      @db.Text
  skinObservations String?      @db.Text
  moistureLevel    Int? // 1-5
  oilinessLevel    Int? // 1-5
  urgencyLevel     Priority     @default(NORMAL)
  recordedById     String       @db.Uuid
  recordedBy       User         @relation(fields: [recordedById], references: [id], onDelete: Restrict)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([patientId])
  @@index([appointmentId])
  @@index([recordedById])
  @@index([patientId, createdAt(sort: Desc)]) // patient vitals timeline
  @@index([urgencyLevel]) // urgent-vitals queue sort
  @@index([recordedById, createdAt(sort: Desc)]) // "my recorded vitals"
  @@map("vitals")
}

// ---- Doctor Scheduling ----

model DoctorSchedule {
  id            String    @id @default(uuid()) @db.Uuid
  doctorId      String    @db.Uuid
  doctor        User      @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  dayOfWeek     DayOfWeek
  startTime     String    @db.VarChar(5) // "09:00"
  endTime       String    @db.VarChar(5) // "17:00"
  breakStart    String?   @db.VarChar(5) // "13:00"
  breakEnd      String?   @db.VarChar(5) // "14:00"
  slotMinutes   Int       @default(30) // appointment slot duration
  maxPatients   Int? // max per day, null = unlimited
  isActive      Boolean   @default(true)
  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date // null = indefinite
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([doctorId, dayOfWeek, effectiveFrom])
  @@index([doctorId])
  @@index([doctorId, dayOfWeek, isActive])
  @@map("doctor_schedules")
}

// ---- Consent Forms ----

model ConsentForm {
  id            String        @id @default(uuid()) @db.Uuid
  patientId     String        @db.Uuid
  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Restrict)
  appointmentId String?       @db.Uuid
  appointment   Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  title         String        @db.VarChar(200) // "Laser Treatment Consent"
  templateKey   String?       @db.VarChar(60) // links to a consent template
  content       String        @db.Text // the actual consent text
  status        ConsentStatus @default(PENDING)
  signedAt      DateTime?
  signatureUrl  String?       @db.Text // stored signature image
